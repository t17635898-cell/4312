local flyBV, flyBG
RunService.RenderStepped:Connect(function()
    if library_unloaded then return end
    
    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if Toggles.Fly and Toggles.Fly.Value and root and hum then
        hum.PlatformStand = true
        
        if not flyBV then
            flyBV = Instance.new("BodyVelocity")
            flyBV.MaxForce = Vector3.new(1e9, 1e9, 1e9)
            flyBV.Parent = root
        end
        if not flyBG then
            flyBG = Instance.new("BodyGyro")
            flyBG.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
            flyBG.P = 9000
            flyBG.Parent = root
        end
        
        flyBG.CFrame = Cam.CFrame
        local dir = Vector3.zero
        
        -- PC 전용 키보드 입력
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir = dir - Vector3.yAxis end
        
        -- 모바일 (터치 조이스틱) 및 크로스 플랫폼 입력 지원
        if dir == Vector3.zero and hum.MoveDirection.Magnitude > 0 then
            -- 캐릭터의 실제 이동 방향(MoveDirection)을 카메라 기준으로 매핑하여 플라이 제어
            local moveDir = hum.MoveDirection
            dir = Cam.CFrame.LookVector * (Cam.CFrame.LookVector * Vector3.new(1,0,1)).Unit:Dot(moveDir) 
                + Cam.CFrame.RightVector * Cam.CFrame.RightVector:Dot(moveDir)
        end
        
        -- 모바일 점프 버튼 감지
        if hum.Jump then
            dir = dir + Vector3.yAxis
        end
        
        if dir.Magnitude > 0 then
            flyBV.Velocity = dir.Unit * Options.FlySpeed.Value
        else
            flyBV.Velocity = Vector3.zero
        end
    else
        if flyBV then flyBV:Destroy(); flyBV = nil end
        if flyBG then flyBG:Destroy(); flyBG = nil end
        if hum and hum.PlatformStand then hum.PlatformStand = false end
    end
end)
