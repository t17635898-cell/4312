local function getOrCreateESP(p)
    if not ESP_Objects[p] then
        local obj = {}
        obj.box = Drawing.new("Square"); obj.box.Thickness = 1; obj.box.Filled = false
        obj.fill = Drawing.new("Square"); obj.fill.Transparency = 0.5; obj.fill.Filled = true; obj.fill.Thickness = 0
        obj.hb = Drawing.new("Square"); obj.hb.Filled = true; obj.hb.Thickness = 0
        obj.name = Drawing.new("Text"); obj.name.Center = true; obj.name.Outline = true
        obj.dist = Drawing.new("Text"); obj.dist.Center = true; obj.dist.Outline = true
        obj.wpn = Drawing.new("Text"); obj.wpn.Center = true; obj.wpn.Outline = true
        obj.sk = { Drawing.new("Line"), Drawing.new("Line"), Drawing.new("Line"), Drawing.new("Line"), Drawing.new("Line") }
        ESP_Objects[p] = obj
    end
    return ESP_Objects[p]
end

local function clearESP(p)
    if ESP_Objects[p] then
        for _, d in pairs(ESP_Objects[p]) do
            if type(d) == "table" then for _, l in ipairs(d) do l:Remove() end else d:Remove() end
        end
        ESP_Objects[p] = nil
    end
    if AuraObjects[p] then
        for _, a in ipairs(AuraObjects[p]) do a:Destroy() end
        AuraObjects[p] = nil
    end
end

Players.PlayerRemoving:Connect(clearESP)

RunService.RenderStepped:Connect(function()
    if library_unloaded then return end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") then
            local char = p.Character; local hrp = char.HumanoidRootPart; local hum = char.Humanoid
