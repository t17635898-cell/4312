local function getDirectImageUrl(url)
    if not url or url == "" then return nil end
    if url:match("^https?://.+") then
        if url:match("%.png$") or url:match("%.jpg$") or url:match("%.jpeg$") or url:match("%.webp$") then return url end
        local res = game:HttpGet(url); local match = res:match('og:image"%s*content="(.-)"')
        if match and match:match("^https?://.+") then if not (match:match("%.png$") or match:match("%.jpg$") or match:match("%.jpeg$")) then match = match .. ".png" end; return match end
    end
    return nil
