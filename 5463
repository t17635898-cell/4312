                            esp.name.Position = pos - Vector2.new(0, boxSize.Y/2 + 10); esp.name.Visible = true
                        else esp.name.Visible = false end
                        
                        if Toggles.EspDistance.Value then
                            esp.dist.Text = string.format("[%.0f]", dist); esp.dist.Size = Options.EspDistanceSize.Value; esp.dist.Color = Options.EspDistanceColor.Value
                            esp.dist.Position = pos + Vector2.new(0, boxSize.Y/2 + 5); esp.dist.Visible = true
                        else esp.dist.Visible = false end
                        
                        if Toggles.EspWeapon.Value then
                            local item = p.Character:FindFirstChildOfClass("Tool")
                            esp.wpn.Text = item and item.Name or "None"; esp.wpn.Size = Options.EspWeaponSize.Value; esp.wpn.Color = Options.EspWeaponColor.Value
                            esp.wpn.Position = pos + Vector2.new(0, boxSize.Y/2 + 20); esp.wpn.Visible = true
                        else esp.wpn.Visible = false end
                        
                        if Toggles.EspSkeleton.Value then
                            local function drawBone(b1, b2, idx)
                                local p1, on1 = Cam:WorldToViewportPoint(b1.Position)
                                local p2, on2 = Cam:WorldToViewportPoint(b2.Position)
                                if on1 and on2 then
                                    esp.sk[idx].From = Vector2.new(p1.X, p1.Y); esp.sk[idx].To = Vector2.new(p2.X, p2.Y)
                                    esp.sk[idx].Color = Options.EspSkeletonColor.Value; esp.sk[idx].Thickness = 1; esp.sk[idx].Visible = true
                                else esp.sk[idx].Visible = false end
                            end
                            local h = char:FindFirstChild("Head"); local t = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                            local ll = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftLowerLeg")
                            local rl = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightLowerLeg")
                            local la = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftLowerArm")
                            local ra = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightLowerArm")
                            if h and t then drawBone(h, t, 1) else esp.sk[1].Visible = false end
                            if t and ll then drawBone(t, ll, 2) else esp.sk[2].Visible = false end
                            if t and rl then drawBone(t, rl, 3) else esp.sk[3].Visible = false end
                            if t and la then drawBone(t, la, 4) else esp.sk[4].Visible = false end
                            if t and ra then drawBone(t, ra, 5) else esp.sk[5].Visible = false end
                        else
                            for i=1, 5 do esp.sk[i].Visible = false end
                        end
                    else
                        for _, d in pairs(esp) do if type(d) == "table" then for _, l in ipairs(d) do l.Visible = false end else d.Visible = false end end
                    end
                else
                    if ESP_Objects[p] then for _, d in pairs(ESP_Objects[p]) do if type(d) == "table" then for _, l in ipairs(d) do l.Visible = false end else d.Visible = false end end end
                end
