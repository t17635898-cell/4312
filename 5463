    for _, conn in ipairs(infiniteParticleConnections) do conn:Disconnect() end
    table.clear(infiniteParticleConnections)
    
    if Toggles.InfiniteParticles and Toggles.InfiniteParticles.Value then
        local function applyParticles(element)
