                    p.Parent = element
                    p:TweenSize(UDim2.new(), "In", "Back", 0.75, true)
                    game:GetService("Debris"):AddItem(p, 1)
                end
            end)
            table.insert(infiniteParticleConnections, conn)
        end
        
        local ui = LP.PlayerGui:FindFirstChild("HUD", true)
        if ui then
            applyParticles(ui:FindFirstChild("Ammo", true))
            applyParticles(ui:FindFirstChild("Reserve", true))
        end
