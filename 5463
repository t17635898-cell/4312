local _s = {
    csyncCF = nil, csyncLV = nil, csyncAV = nil,
    csyncLocalCF = nil, csyncLocalLV = nil, csyncLocalAV = nil,
    csyncConn = nil, noclipConn = nil, rbVoidThread = nil, rbVoidHbConn = nil, rbVoidTargetCF = nil
}

local function StopCsync()
    RunService:UnbindFromRenderStep("sh_csync")
    if _s.csyncConn then _s.csyncConn:Disconnect(); _s.csyncConn = nil end
    _s.csyncCF = nil; _s.csyncLV = nil; _s.csyncAV = nil
end

local function StartCsync()
    StopCsync()
    _s.csyncConn = RunService.Heartbeat:Connect(function()
        local c = LP.Character; local h = c and c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        _s.csyncLocalCF = h.CFrame; _s.csyncLocalLV = h.AssemblyLinearVelocity; _s.csyncLocalAV = h.AssemblyAngularVelocity
        local cf = _s.csyncCF
        if cf then
            h.CFrame = cf
            h.AssemblyLinearVelocity = _s.csyncLV or Vector3.new(math.random(-10000,10000), math.random(-10000,10000), math.random(-10000,10000))
            h.AssemblyAngularVelocity = _s.csyncAV or Vector3.new(math.random(-10000,10000), math.random(-10000,10000), math.random(-10000,10000))
        end
    end)
    RunService:BindToRenderStep("sh_csync", Enum.RenderPriority.First.Value, function()
        local cf = _s.csyncLocalCF; if not cf then return end
        local c = LP.Character; local h = c and c:FindFirstChild("HumanoidRootPart"); if not h then return end
        h.CFrame = cf; h.AssemblyLinearVelocity = _s.csyncLocalLV or Vector3.zero; h.AssemblyAngularVelocity = _s.csyncLocalAV or Vector3.zero
    end)
end

local function EnableNoclip()
    if _s.noclipConn then return end
    _s.noclipConn = RunService.Stepped:Connect(function()
        local lc = LP.Character; if not lc then return end
        for _, p in lc:GetDescendants() do if p:IsA("BasePart") then p.CanCollide = false end end
    end)
end

local function DisableVoidCsync()
    if _s.rbVoidHbConn then _s.rbVoidHbConn:Disconnect(); _s.rbVoidHbConn = nil end
    RunService:UnbindFromRenderStep("sh_rbvoid")
    _s.rbVoidTargetCF = nil; _s.rbVoidThread = nil
end

local function EnableVoidLoop()
    if _s.rbVoidThread then return end
    DisableVoidCsync()
    _s.rbVoidHbConn = RunService.Heartbeat:Connect(function()
        local lc = LP.Character; local h = lc and lc:FindFirstChild("HumanoidRootPart"); if not h then return end
        _s.csyncLocalCF = h.CFrame; _s.csyncLocalLV = h.AssemblyLinearVelocity; _s.csyncLocalAV = h.AssemblyAngularVelocity
        local tcf = _s.rbVoidTargetCF
        if tcf then
            h.CFrame = tcf; h.AssemblyLinearVelocity = Vector3.zero; h.AssemblyAngularVelocity = Vector3.zero
        else
            h.CFrame = CFrame.new(math.random(-2e9,2e9), math.random(-2e9,2e9), math.random(-2e9,2e9))
            h.AssemblyLinearVelocity = Vector3.new(math.random(-2e9,2e9), math.random(-2e9,2e9), math.random(-2e9,2e9))
        end
    end)
    RunService:BindToRenderStep("sh_rbvoid", Enum.RenderPriority.First.Value, function()
        if not _s.csyncLocalCF then return end
        local lc = LP.Character; local h = lc and lc:FindFirstChild("HumanoidRootPart"); if not h then return end
        h.CFrame = _s.csyncLocalCF; h.AssemblyLinearVelocity = _s.csyncLocalLV; h.AssemblyAngularVelocity = _s.csyncLocalAV
    end)

    _s.rbVoidThread = task.spawn(function()
        while Toggles.Void.Value and not library_unloaded do
            _s.rbVoidTargetCF = nil
            if Options.VoidHideTime.Value > 0 then task.wait(Options.VoidHideTime.Value) end
            if not Toggles.Void.Value then break end
            
            local tgt = CurrentTarget
            if tgt and tgt.Character and tgt.Character:FindFirstChild("Head") then
                local thead = tgt.Character.Head
                local shootCF = CFrame.new(thead.Position)
                _s.rbVoidTargetCF = shootCF; _s.csyncCF = shootCF
                if Options.VoidShootTime.Value > 0 then task.wait(Options.VoidShootTime.Value) end
                if Toggles.AutoFire.Value then
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                    task.wait(0.03)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                end
                _s.csyncCF = nil
            end
            task.wait(0.01)
        end
        _s.rbVoidThread = nil; DisableVoidCsync()
    end)
end

local isMovementActive = false
local function UpdateMovementState()
    local shouldActive = Toggles.Underground.Value or Toggles.Orbit.Value or Toggles.Void.Value
    if shouldActive and not isMovementActive then
        isMovementActive = true
        StartCsync()
        EnableNoclip()
    elseif not shouldActive and isMovementActive then
        isMovementActive = false
        StopCsync()
        if _s.noclipConn then _s.noclipConn:Disconnect(); _s.noclipConn = nil end
    end
end

Toggles.Underground:OnChanged(UpdateMovementState)
Toggles.Orbit:OnChanged(UpdateMovementState)
Toggles.Void:OnChanged(UpdateMovementState)

local orbitAngle = math.random() * (math.pi * 2)

RunService.Stepped:Connect(function(_, dt)
    if library_unloaded then return end
    
    if Toggles.Void.Value then
        if not _s.rbVoidThread then EnableVoidLoop() end
        return
    else
        if _s.rbVoidThread then DisableVoidCsync() end
    end

    local lc = LP.Character; local lhrp = lc and lc:FindFirstChild("HumanoidRootPart")
    if not lhrp or not CurrentTarget or not CurrentTarget.Character then 
        _s.csyncCF = nil; _s.csyncLV = nil; _s.csyncAV = nil
        return 
    end

    local tc = CurrentTarget.Character
    local tr = tc:FindFirstChild("HumanoidRootPart")
    local thead = tc:FindFirstChild("Head")
    if not tr or not thead then _s.csyncCF = nil; return end

    local targetPos, targetCF = nil, nil

    if Toggles.Underground.Value then
        targetPos = thead.Position - Vector3.new(0, Options.UndergroundDepth.Value, 0)
        targetCF = CFrame.new(targetPos, thead.Position)
    elseif Toggles.Orbit.Value then
        orbitAngle = orbitAngle + (dt * 5)
        targetPos = thead.Position + Vector3.new(math.cos(orbitAngle) * Options.OrbitDistance.Value, Options.OrbitHeight.Value, math.sin(orbitAngle) * Options.OrbitDistance.Value)
        targetCF = CFrame.new(targetPos, thead.Position)
    else
        local mode = Options.TeleportMode.Value
        local dist = Options.OrbitDistance.Value
        local height = Options.OrbitHeight.Value
        if mode == "Back" then
            targetPos = thead.Position - tr.CFrame.LookVector * dist + Vector3.new(0, height, 0)
        elseif mode == "Side" then
            local dir = math.random() > 0.5 and tr.CFrame.RightVector or -tr.CFrame.RightVector
            targetPos = thead.Position + dir * dist + Vector3.new(0, height, 0)
        elseif mode == "Above" then
            targetPos = thead.Position + Vector3.new(0, dist, 0)
        end
        if targetPos then targetCF = CFrame.new(targetPos, thead.Position) end
    end

    if targetCF then
        local oldPos = _s.csyncCF and _s.csyncCF.Position
        _s.csyncCF = targetCF
        _s.csyncLV = (oldPos and dt > 0) and (targetPos - oldPos) / dt or Vector3.zero
        _s.csyncAV = Vector3.zero
    else
        _s.csyncCF = nil; _s.csyncLV = nil; _s.csyncAV = nil
    end
end)

